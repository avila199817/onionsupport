{
  "routes": [
    {
      "route": "/@*",
      "rewrite": "/es/acceso/admin/index.html"
    }
  ],
  "navigationFallback": {
    "rewrite": "/es/acceso/admin/index.html",
    "exclude": [
      "/css/*",
      "/js/*",
      "/media/*",
      "/api/*",
      "/pages/*",
      "/robots.txt",
      "/sitemap.xml",
      "/favicon.ico"
    ]
  }
}